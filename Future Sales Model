         color='orange', linewidth=2, linestyle='--', marker='o', label='2018 Forecast')
ax1.axvspan(future_df['Date'].iloc[0], future_df['Date'].iloc[-1],
            alpha=0.1, color='orange')
ax1.set_title('Sales History + 2018 Forecast')
